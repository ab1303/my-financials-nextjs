{
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"],
      "@/components/*": ["./src/components/*"],
      "@/config/*": ["./src/config/*"],
      "@/features/*": ["./src/features/*"],
      "@/helpers/*": ["./src/helpers/*"],
      "@/layouts/*": ["./src/layouts/*"],
      "@/server/*": ["./src/server/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/types/*": ["./src/types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/static-props/*": ["./src/static-props/*"]
    }
  }
}
