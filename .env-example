# Since .env is gitignored, you can use .env-example to build a new `.env` file when you clone the repo.

# Keep this file up-to-date when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any secrets in it.

# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# When adding additional env variables, the schema in /env/schema.mjs should be updated accordingly

# Prisma

DATABASE_URL=file:./db.sqlite

# Auth.js (NextAuth v5)

# You can generate the secret via 'openssl rand -base64 32' on Linux

# More info: https://authjs.dev/getting-started/installation

AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Auth.js Providers (optional)

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# E2E Test Database (only needed when running Playwright tests locally)

# E2E_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/financials_e2e_test"

# AI Image Import Configuration

# AI Provider: github | openai

# github = GitHub Models (free tier, uses GitHub PAT)

# openai = OpenAI API (paid, requires OpenAI API key)

AI_PROVIDER=github

# AI Inference Base URL (optional ΓÇö overrides the default for the selected provider)

# GitHub Models default: https://models.inference.ai.azure.com

# OpenAI default: https://api.openai.com/v1

# Leave blank to use the provider default

AI_BASE_URL=

# AI Vision Model identifier

# For GitHub Models: gpt-4o-mini (recommended free tier), gpt-4o

# For OpenAI: gpt-4o, gpt-4o-mini

AI_VISION_MODEL=gpt-4o-mini

# AI Provider API Key

# For GitHub Models: a GitHub Personal Access Token (PAT) ΓÇö free, no credit card needed

# For OpenAI: API key starting with sk-

AI_API_KEY=

# Image Storage Configuration

# Provider: local | s3 (defaults to local for development)

IMAGE_STORAGE_PROVIDER=local

# AWS S3 Configuration (required if IMAGE_STORAGE_PROVIDER=s3)

# AWS S3 bucket name

AWS_S3_BUCKET=

# AWS region (e.g., us-east-1, ap-southeast-2)

AWS_S3_REGION=

# AWS IAM access key

AWS_ACCESS_KEY_ID=

# AWS IAM secret access key

AWS_SECRET_ACCESS_KEY=

# AI Import Image TTL (days) ΓÇö images older than this will be deleted by the cleanup job

# Defaults to 7 days if not set

AI_IMPORT_IMAGE_TTL_DAYS=7

# Cron Secret ΓÇö used to authenticate the Vercel Cron call to /api/ai-import/cleanup

# Generate a random string: openssl rand -hex 32

CRON_SECRET=

# AI Embedding Model identifier (used for semantic category matching)

# Default: text-embedding-3-small (1536 dimensions, $0.02/1M tokens)

# Alternative: text-embedding-3-large (3072 dimensions, $0.13/1M tokens)

AI_EMBEDDING_MODEL=text-embedding-3-small

# Minimum cosine similarity threshold for embedding-based category matching

# Range: 0.0 to 1.0 (higher = stricter matching)

# Default: 0.75

AI_EMBEDDING_SIMILARITY_THRESHOLD=0.75
