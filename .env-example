# Since .env is gitignored, you can use .env-example to build a new `.env` file when you clone the repo.

# Keep this file up-to-date when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any secrets in it.

# If you are cloning this repo, create a copy of this file named `.env` and populate it with your secrets.

# When adding additional env variables, the schema in /env/schema.mjs should be updated accordingly

# Prisma

DATABASE_URL=file:./db.sqlite

# Auth.js (NextAuth v5)

# You can generate the secret via 'openssl rand -base64 32' on Linux

# More info: https://authjs.dev/getting-started/installation

AUTH_SECRET=
AUTH_URL=http://localhost:3000

# Auth.js Providers (optional)

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# E2E Test Database (only needed when running Playwright tests locally)

# E2E_DATABASE_URL="postgresql://postgres:postgres@localhost:5433/financials_e2e_test"

# AI Image Import Configuration

# AI Provider: openai | google | anthropic

AI_PROVIDER=openai

# AI Vision Model identifier

# For OpenAI: gpt-4o

# For Google: gemini-1.5-pro

# For Anthropic: claude-sonnet-4-20250514

AI_VISION_MODEL=gpt-4o

# AI Provider API Key

# For OpenAI: starts with sk-

# For Google: obtained from Google Cloud Console

# For Anthropic: obtained from Anthropic Console

AI_API_KEY=

# Image Storage Configuration

# Provider: local | vercel-blob | s3 (defaults to local for development)

IMAGE_STORAGE_PROVIDER=local

# Vercel Blob Storage token (required if IMAGE_STORAGE_PROVIDER=vercel-blob)

# Obtain from https://vercel.com/account/settings/tokens

VERCEL_BLOB_TOKEN=

# AWS S3 Configuration (required if IMAGE_STORAGE_PROVIDER=s3)

# AWS S3 bucket name

AWS_S3_BUCKET=

# AWS region (e.g., us-east-1, ap-southeast-2)

AWS_S3_REGION=

# AWS IAM access key

AWS_ACCESS_KEY_ID=

# AWS IAM secret access key

AWS_SECRET_ACCESS_KEY=

# AI Import Image TTL (days) — images older than this will be deleted by the cleanup job

# Defaults to 7 days if not set

AI_IMPORT_IMAGE_TTL_DAYS=7

# Cron Secret — used to authenticate the Vercel Cron call to /api/ai-import/cleanup

# Generate a random string: openssl rand -hex 32

CRON_SECRET=
